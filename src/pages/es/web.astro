---
import MainLayout from '../../layouts/MainLayout.astro';
import webProjects from '../../data/web.json';

const lang = "es";

const t = {
  fr: {
    badge: "Architecture Web",
    title_1: "Web",
    title_2: "Development",
    description: "Écosystèmes web statiques ultra-rapides. Sécurité totale, SEO natif et interfaces métier connectées.",
    details: "Détails du projet",
    visit: "Visiter le site web",
    features: "Points clés",
    more: "En savoir plus +"
  },
  es: {
    badge: "Arquitectura Web",
    title_1: "Desarrollo",
    title_2: "Web",
    description: "Ecosistemas web estáticos ultrarrápidos. Seguridad total, SEO nativo e interfaces conectadas.",
    details: "Detalles del proyecto",
    visit: "Visitar el sitio web",
    features: "Puntos clave",
    more: "Saber más +"
  },
  en: {
    badge: "Web Architecture",
    title_1: "Web",
    title_2: "Development",
    description: "Ultra-fast static web ecosystems. Total security, native SEO, and connected business interfaces.",
    details: "Project details",
    visit: "Visit website",
    features: "Key features",
    more: "Learn more +"
  }
};
---

<MainLayout lang={lang} title={`${t[lang].title_1} ${t[lang].title_2} | Hexagone`}>
  <div class="max-w-6xl mx-auto px-6 py-12">
    
    <header class="bg-[#0e1f2b] rounded-[2.5rem] p-10 md:p-16 mb-12 relative overflow-hidden shadow-2xl">
      <div class="relative z-10">
        <span class="text-[#00a0c5] font-black tracking-[0.3em] uppercase text-[10px]">{t[lang].badge}</span>
        <h1 class="text-4xl md:text-6xl font-black text-white mt-4 uppercase italic tracking-tighter leading-none">
          {t[lang].title_1} <span class="text-[#00a0c5]">{t[lang].title_2}</span>
        </h1>
        <p class="text-slate-400 mt-6 max-w-2xl text-lg leading-relaxed">{t[lang].description}</p>
      </div>
      <i class="fas fa-code absolute right-[-20px] bottom-[-20px] opacity-10 text-[12rem] rotate-12 text-white"></i>
    </header>

    <div class="grid md:grid-cols-2 gap-8">
      {webProjects.map((project) => (
        <article class="group bg-white border border-slate-200 rounded-[2.5rem] p-8 md:p-10 hover:shadow-xl transition-all duration-300 flex flex-col justify-between">
          <div>
            <span class="text-[#00a0c5] text-[10px] font-black uppercase tracking-widest px-3 py-1 bg-slate-50 rounded-full border border-slate-100 italic">
              {project.category}
            </span>
            <h3 class="text-2xl font-black uppercase italic text-[#0e1f2b] mt-4 mb-2">{project.name}</h3>
            <p class="text-[#00a0c5] text-[10px] font-bold uppercase tracking-widest mb-6">{project.tagline[lang]}</p>
          </div>

          <button 
            onclick={`document.getElementById('modal-${project.id}').showModal()`}
            class="w-full py-4 bg-slate-50 rounded-2xl font-black text-[10px] uppercase tracking-widest text-[#0e1f2b] hover:bg-[#0e1f2b] hover:text-white transition-all"
          >
            {t[lang].more}
          </button>

          <dialog id={`modal-${project.id}`} class="backdrop:blur-md p-0 rounded-[2.5rem] shadow-2xl border-none max-w-2xl w-full overflow-hidden">
            <div class="p-8 md:p-12 relative bg-white">
              <button onclick={`this.closest('dialog').close()`} class="absolute top-6 right-6 text-slate-400 hover:text-[#0e1f2b]">
                <i class="fas fa-times text-xl"></i>
              </button>
              
              <span class="text-[#00a0c5] text-[10px] font-black uppercase tracking-[0.3em] mb-2 block">{t[lang].details}</span>
              <h2 class="text-3xl font-black uppercase italic text-[#0e1f2b] mb-6">{project.name}</h2>
              
              <div class="space-y-6">
                <p class="text-lg text-slate-700 leading-relaxed">{project.description[lang]}</p>

                <div class="grid grid-cols-2 gap-4 py-6 border-t border-slate-100">
                  {project.features?.map((feat) => (
                    <div class="flex items-center gap-2 text-slate-700">
                      <i class="fas fa-check text-[#00a0c5] text-[10px]"></i>
                      <span class="text-xs font-medium">{feat}</span>
                    </div>
                  ))}
                </div>
                
                <div class="pt-6 border-t border-slate-100 flex flex-col md:flex-row gap-6 items-center justify-between">
                  <div class="flex flex-wrap gap-2">
                    {project.tech.map((tech) => (
                      <span class="px-3 py-1 bg-slate-100 rounded-md text-[9px] font-bold text-slate-500 uppercase italic">#{tech}</span>
                    ))}
                  </div>
                  
                  <a href={project.url} target="_blank" class="w-full md:w-auto px-8 py-3 bg-[#00a0c5] text-white rounded-xl font-black text-[10px] uppercase tracking-widest hover:bg-[#0e1f2b] transition-all text-center">
                    {t[lang].visit} <i class="fas fa-external-link-alt ml-2"></i>
                  </a>
                </div>
              </div>
            </div>
          </dialog>
        </article>
      ))}
    </div>
  </div>
</MainLayout>

<style>
  dialog::backdrop { background: rgba(14, 31, 43, 0.7); }
  dialog[open] { animation: zoomIn 0.3s cubic-bezier(0.34, 1.56, 0.64, 1); }
  @keyframes zoomIn { from { opacity: 0; transform: scale(0.95); } to { opacity: 1; transform: scale(1); } }
</style>