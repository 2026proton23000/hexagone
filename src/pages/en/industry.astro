---
import MainLayout from '../../layouts/MainLayout.astro';
import industries from '../../data/industries.json';
const lang = "en";
---

<MainLayout lang={lang} title="Secteurs d'Intervention | Hexagone">
  <div class="py-12">
    <div class="mb-16">
        <span class="text-[#00a0c5] font-bold tracking-widest uppercase text-sm italic">Expertise Terrain</span>
        <h1 class="text-5xl font-black text-[#0e1f2b] mt-2 uppercase italic tracking-tighter">Nos secteurs d'impact</h1>
        <div class="h-1.5 w-24 bg-[#00a0c5] mt-4"></div>
    </div>

    <div class="grid md:grid-cols-3 gap-8">
      {industries.map((item) => (
        <div class="bg-white border border-[#bfd8e4] rounded-3xl p-8 shadow-sm hover:shadow-xl hover:border-[#00a0c5] transition-all group">
          <div class="w-16 h-16 bg-[#e2f0f7] border border-[#bddbe9] rounded-2xl flex items-center justify-center text-[#00799e] text-2xl mb-6 group-hover:bg-[#00a0c5] group-hover:text-white transition-colors">
            <i class={`fas ${item.icon}`}></i>
          </div>
          <h3 class="text-2xl font-bold text-[#14313f] mb-4 uppercase tracking-tight">{item.title[lang]}</h3>
          <p class="text-[#3c6275] leading-relaxed mb-8 h-24">
            {item.description[lang]}
          </p>
          <a 
            href={`/${lang}/software#${item.linked_app}`} 
            class="inline-flex items-center gap-2 font-bold text-[#007396] border-b-2 border-dashed border-[#00a0c5] pb-1 hover:gap-4 transition-all"
          >
            Voir la solution technique <i class="fas fa-arrow-right text-sm"></i>
          </a>
        </div>
      ))}
    </div>
  </div>
</MainLayout>