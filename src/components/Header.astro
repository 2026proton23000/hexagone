---
import LanguagePicker from './LanguagePicker.astro';
const { lang } = Astro.props;

const menu = {
  fr: [
    { name: "Industrie", href: `/${lang}/industry` },
    { name: "Logiciel", href: `/${lang}/software` },
    { name: "Web Development", href: `/${lang}/web` },
    { name: "Contact", href: `/${lang}/contact` },
  ],
  es: [
    { name: "Industria", href: `/${lang}/industry` },
    { name: "Software", href: `/${lang}/software` },
    { name: "Desarrollo Web", href: `/${lang}/web` },
    { name: "Contacto", href: `/${lang}/contact` },
  ],
  en: [
    { name: "Industry", href: `/${lang}/industry` },
    { name: "Software", href: `/${lang}/software` },
    { name: "Web Development", href: `/${lang}/web` },
    { name: "Contact", href: `/${lang}/contact` },
  ]
};
---
<header>
  <nav class="bg-white border-b-4 border-[#00a0c5] sticky top-0 z-50 shadow-sm">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex justify-between h-20">
        <div class="flex items-center">
          <a href={`/${lang}/`} class="flex-shrink-0 flex flex-col">
            <span class="font-black text-2xl text-[#0e1f2b] tracking-tighter uppercase">HEXAGONE</span>
            <span class="text-[10px] text-[#4f6b7a] tracking-[0.2em] uppercase font-medium">Engineering & Software</span>
          </a>
          <div class="hidden md:ml-10 md:flex md:space-x-8">
            {menu[lang].map(item => (
              <a href={item.href} class="text-[#1e2b37] hover:text-[#00a0c5] px-3 py-2 text-sm font-bold uppercase tracking-wide transition-colors">
                {item.name}
              </a>
            ))}
          </div>
        </div>
        <div class="flex items-center gap-4">
          <LanguagePicker currentLang={lang} />
          <button id="menu-btn" class="md:hidden p-2 text-[#00a0c5]">
              <i class="fas fa-bars text-2xl"></i>
          </button>
        </div>
      </div>
    </div>

    <div id="mobile-menu" class="hidden md:hidden bg-white border-t border-slate-100 px-4 py-4 space-y-2 shadow-xl">
      {menu[lang].map(item => (
        <a href={item.href} class="block text-[#1e2b37] font-bold py-3 border-b border-slate-50 last:border-0 uppercase tracking-wide">
          {item.name}
        </a>
      ))}
    </div>
  </nav>
</header>

<script>
  const btn = document.getElementById('menu-btn');
  const menu = document.getElementById('mobile-menu');
  btn?.addEventListener('click', () => menu?.classList.toggle('hidden'));
</script>