---
// 1. Récupérer la base (/hexagone)
const base = import.meta.env.BASE_URL.replace(/\/$/, ''); // On enlève le slash final s'il existe

const { currentLang } = Astro.props;
const { pathname } = Astro.url;

const languages = {
  fr: { label: 'FR', flag: '🇫🇷' },
  es: { label: 'ES', flag: '🇵🇪' },
  en: { label: 'EN', flag: '🇺🇸' }
};

function getLocalizedLink(targetLang) {
  // On nettoie l'URL pour ne garder que les segments utiles
  // Exemple : "/hexagone/fr/web" -> ["hexagone", "fr", "web"]
  const segments = pathname.split('/').filter(Boolean);
  
  // Cas A : On est sur GitHub Pages (le premier segment est "hexagone")
  // On cherche l'index de la langue actuelle dans les segments
  const langIndex = segments.findIndex(s => s === currentLang);

  if (langIndex !== -1) {
    // On remplace juste la langue à son emplacement précis
    segments[langIndex] = targetLang;
    return `/${segments.join('/')}/`;
  }

  // Cas B : Sécurité (si la langue n'est pas trouvée dans l'URL)
  return `${base}/${targetLang}/`;
}
---

<div class="flex gap-4">
  {Object.entries(languages).map(([code, { label, flag }]) => (
    <a 
      href={getLocalizedLink(code)}
      class={`text-[10px] font-black px-2 py-1 rounded border transition-all ${currentLang === code ? 'border-[#00a0c5] text-[#00a0c5] bg-[#00a0c5]/10' : 'border-slate-800 text-slate-500 hover:border-slate-600'}`}
    >
      {flag} {label}
    </a>
  ))}
</div>